// LD2L — Learn Dota 2 League
// SQLite is used for zero-config local dev + easy end-to-end testing.
// NOTE: SQLite does not support Prisma enums, so status/type/role fields are
// Strings validated in app code (see src/lib/constants.ts). This is structured
// so a later switch to Postgres (with real enums) is a mechanical change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  steamId    String   @unique
  name       String
  avatar        String?
  profileUrl    String?
  dotaAccountId Int? // Dota 2 32-bit account id (defaults to one derived from steamId)
  rankTier      Int? // OpenDota rank_tier (tens=medal, ones=stars); null if unknown
  // OpenDota profile.fh_unavailable: true = "Expose Public Match Data" is OFF,
  // so every automatic import path is blind to this player's games. Null =
  // unknown (never fetched / OpenDota didn't say). Refreshed wherever the
  // medal is (login, /me refresh, admin bulk sync); never overwritten on a
  // failed fetch — same rule as rankTier.
  fhUnavailable Boolean?
  // Discord username — the league runs on Discord, and this is how captains
  // reach their roster. Empty string = not provided. Persists across seasons.
  discordName   String   @default("")
  // Discord account link (OAuth2 `identify`): the snowflake id, set ONLY by
  // the OAuth callback — proof the player owns that Discord account, unlike
  // the typed discordName fallback. @unique stops two site accounts claiming
  // the same Discord account. Null = not linked. No tokens are ever stored.
  discordId     String?  @unique
  role          String   @default("USER") // USER | ADMIN
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations       Registration[]
  teamMemberships     TeamMember[]
  captainedTeams      Team[]              @relation("TeamCaptain")
  bids                Bid[]
  standinAssignments  StandinAssignment[] @relation("StandinUser")
  replacedAssignments StandinAssignment[] @relation("ReplacedUser")
  inhouseQueue        InhouseQueueEntry?
  inhouseLobbies      InhouseLobbyPlayer[]
  startedInhouses     InhouseLobby[]      @relation("InhouseStarter")
  matchAvailability   MatchAvailability[]
  rescheduleProposals RescheduleRequest[]
  fantasyRosters      FantasyRoster[]
  fantasyPickedBy     FantasyPick[]
  predictions         Prediction[]
  newsPosts           NewsPost[]
}

// Admin-authored league announcements, shown on the dashboard + /news.
model NewsPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  pinned    Boolean  @default(false)
  authorId  String?
  createdAt DateTime @default(now())

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Season {
  id             String   @id @default(cuid())
  name           String
  status         String   @default("SIGNUPS") // SIGNUPS | DRAFT | REGULAR_SEASON | PLAYOFFS | COMPLETE
  minTeams       Int      @default(4)
  teamSize       Int      @default(5)
  draftBudget    Int      @default(100)
  budgetMmrWeight Int     @default(20) // % budget swing by captain MMR (low-MMR captains get more; 0 = flat budgets)
  maxMmr         Int      @default(0) // signup MMR cap; players above it can't join (0 = no cap)
  regularBestOf  Int      @default(2) // series length for regular-season matches
  playoffBestOf  Int      @default(3) // series length for playoff (non-final) matches
  finalBestOf    Int      @default(5) // series length for the grand final
  currentWeek    Int      @default(0)
  isActive       Boolean  @default(true)
  championTeamId String?
  dotaLeagueId   String? // optional Valve league id, if the league is ticketed
  matchSchedule  String? // weekly match slot shown before signup (null = app default)
  firstMatchNight DateTime? // week 1's match time; later weeks (incl. playoffs) are +7d each
  // When the live auction happens — announced with countdowns during SIGNUPS.
  draftAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registrations Registration[]
  teams         Team[]
  draft         Draft?
  matches       Match[]
  teamMembers   TeamMember[]
  bids          Bid[]
  fantasyRosters FantasyRoster[]
}

model Registration {
  id           String   @id @default(cuid())
  seasonId     String
  userId       String
  type         String   @default("PLAYER") // PLAYER | STANDIN
  mmr          Int      @default(0)
  wantsCaptain   Boolean  @default(false)
  roles          String   @default("") // preferred positions, comma-separated 1-5
  favoriteHeroes String   @default("")
  statement      String   @default("") // what the player wants from the league
  captainNote    String   @default("") // message to captains/drafters
  status         String   @default("ACTIVE") // ACTIVE | WITHDRAWN
  createdAt      DateTime @default(now())

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  // Hot counts/pool queries filter seasonId+status+type; userId lookups
  // (returning-player prefill, profiles) can't use the unique (userId isn't
  // its leftmost column).
  @@index([seasonId, status, type])
  @@index([userId])
}

model Team {
  id         String   @id @default(cuid())
  seasonId   String
  name       String
  captainId  String
  budget     Int      @default(100)
  draftOrder Int      @default(0)
  createdAt  DateTime @default(now())

  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  captain     User         @relation("TeamCaptain", fields: [captainId], references: [id])
  members     TeamMember[]
  bids        Bid[]
  homeMatches Match[]      @relation("HomeTeam")
  awayMatches Match[]      @relation("AwayTeam")
  predictions Prediction[]

  @@unique([seasonId, captainId])
}

model TeamMember {
  id        String   @id @default(cuid())
  seasonId  String
  teamId    String
  userId    String
  price     Int      @default(0)
  isCaptain Boolean  @default(false)
  createdAt DateTime @default(now())

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  // Roster include (team.members) filters teamId; career pages filter userId —
  // neither is the leftmost column of the unique above.
  @@index([teamId])
  @@index([userId])
}

// Singleton per season — server-authoritative auction draft state.
model Draft {
  id               String    @id @default(cuid())
  seasonId         String    @unique
  status           String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | PAUSED | COMPLETE
  nominatorTeamId  String?
  nominatedUserId  String?
  currentBid       Int       @default(0)
  currentBidTeamId String?
  bidEndsAt        DateTime?
  nominationEndsAt DateTime? // deadline for the team on the clock to nominate
  nominationIndex  Int       @default(0)
  updatedAt        DateTime  @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  bids   Bid[]
}

model Bid {
  id        String   @id @default(cuid())
  draftId   String
  seasonId  String
  teamId    String
  userId    String // the player being bid on
  amount    Int
  createdAt DateTime @default(now())

  draft  Draft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([draftId])
}

model Match {
  id           String    @id @default(cuid())
  seasonId     String
  week         Int
  phase        String    @default("REGULAR") // REGULAR | PLAYOFF | FINAL
  homeTeamId   String
  awayTeamId   String
  scheduledAt  DateTime?
  status       String    @default("SCHEDULED") // SCHEDULED | LIVE | COMPLETED
  homeScore    Int       @default(0)
  awayScore    Int       @default(0)
  bestOf       Int       @default(1) // series length; a team clinches at floor(bestOf/2)+1
  winnerTeamId String?
  bracketSlot  String?
  // Last automatic OpenDota scan for this match (result-sync-service). Updated
  // via an atomic claim so concurrent pollers can't double-scan — the inhouse
  // `detectedAt` pattern.
  autoSyncedAt DateTime?
  // Consecutive empty automatic scans — drives exponential backoff so a match
  // that never produces games (forfeit, private match data) stops burning the
  // OpenDota budget. Reset to 0 whenever a scan imports a game.
  autoSyncAttempts Int   @default(0)
  createdAt    DateTime  @default(now())

  season       Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeam     Team                @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team                @relation("AwayTeam", fields: [awayTeamId], references: [id])
  standins     StandinAssignment[]
  games        Game[]
  availability MatchAvailability[]
  predictions  Prediction[]
  reschedules  RescheduleRequest[]

  // seasonId is filtered on nearly every mid-season page; team pages/standings
  // filter home/away team ids.
  @@index([seasonId])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

// A captain's proposal to move a match to a different time. The opposing
// captain accepts (retimes the match) or declines; one open proposal per
// match at a time.
model RescheduleRequest {
  id           String   @id @default(cuid())
  matchId      String
  proposedById String
  proposedTime DateTime
  status       String   @default("PENDING") // PENDING | ACCEPTED | DECLINED | CANCELLED
  createdAt    DateTime @default(now())

  match      Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  proposedBy User  @relation(fields: [proposedById], references: [id], onDelete: Cascade)

  @@index([matchId, status])
}

// A rostered player's match-night RSVP for a scheduled match. Captains and the
// admin see who's confirmed and who needs a standin before lobby time.
model MatchAvailability {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  status    String // IN | OUT
  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model StandinAssignment {
  id              String   @id @default(cuid())
  matchId         String
  teamId          String
  standinUserId   String
  replacingUserId String?
  createdAt       DateTime @default(now())

  match    Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  standin  User  @relation("StandinUser", fields: [standinUserId], references: [id])
  replaced User? @relation("ReplacedUser", fields: [replacingUserId], references: [id])

  @@index([matchId])
}

// An individual Dota 2 game fetched from OpenDota, rolled up into a league Match.
// A league Match (series) can contain several games (Bo1/Bo2/Bo3…).
model Game {
  id            String   @id @default(cuid())
  matchId       String
  dotaMatchId   String   @unique
  radiantWin    Boolean
  durationSecs  Int      @default(0)
  startTime     Int      @default(0)
  radiantScore  Int      @default(0)
  direScore     Int      @default(0)
  radiantTeamId String?
  direTeamId    String?
  winnerTeamId  String?
  players       String   @default("[]") // JSON: per-player stats mapped to our users where known
  fetchedAt     DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Every stat roll-up joins game → match; recomputeSeries loads a match's games.
  @@index([matchId])
}

// Simple key/value store for global config (e.g. activeSeasonId).
model Setting {
  key   String @id
  value String
}

// ---------------------------------------------------------------------------
// Inhouse — a casual pick-up-game mode, entirely separate from the league. A
// rolling queue: once INHOUSE.LOBBY_SIZE players are waiting a lobby forms, the
// two highest-MMR players captain, and they draft the rest back-and-forth.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Fantasy — every league member picks a "fantasy five" from the drafted
// rosters under an MMR salary cap; points score from imported game stats.
// ---------------------------------------------------------------------------

model FantasyRoster {
  id        String   @id @default(cuid())
  seasonId  String
  userId    String // the fantasy manager (any signed-in user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  picks  FantasyPick[]

  @@unique([seasonId, userId])
}

model FantasyPick {
  id       String @id @default(cuid())
  rosterId String
  userId   String // the drafted league player being picked

  roster FantasyRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  player User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rosterId, userId])
}

// Pick'em: one predicted winner per user per match. Locks at the match's
// scheduled start (or completion); graded against Match.winnerTeamId.
model Prediction {
  id           String   @id @default(cuid())
  matchId      String
  userId       String
  pickedTeamId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  picked Team  @relation(fields: [pickedTeamId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  // Per-user oracle history (userId isn't the unique's leftmost column).
  @@index([userId])
}

// A single global queue of players waiting for the next inhouse. One row per
// user (a user can only wait once); the earliest to join are pulled into a lobby.
model InhouseQueueEntry {
  id       String   @id @default(cuid())
  userId   String   @unique
  mmr      Int      @default(0) // snapshot used to seed captains
  joinedAt DateTime @default(now())
  // Presence heartbeat — refreshed (throttled) by the player's own /inhouse
  // polls. Entries that go silent stop counting toward a lobby, then drop.
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// A formed inhouse game + its live captain draft. Server-authoritative, like the
// league Draft: the pick clock is enforced lazily on poll (no cron/websocket).
model InhouseLobby {
  id          String    @id @default(cuid())
  status      String    @default("CAPTAIN_VOTE") // CAPTAIN_VOTE | DRAFTING | READY | IN_PROGRESS | COMPLETED | CANCELLED
  voteEndsAt  DateTime? // captain-selection vote deadline (CAPTAIN_VOTE phase)
  pickTeam    Int? // 1 | 2 — team on the clock while DRAFTING
  pickEndsAt  DateTime? // captain auto-picks when this passes
  radiantTeam Int       @default(1) // which team (1|2) plays Radiant
  winnerTeam  Int? // 1 | 2 once a result is reported
  startedById String? // who launched the in-game lobby
  startedAt   DateTime? // when the game was launched (IN_PROGRESS)
  dotaMatchId String? // OpenDota match id, once the result is recorded
  detectedAt  DateTime? // throttles the automatic OpenDota result scan
  durationSecs Int? // game length once recorded
  radiantScore Int? // Radiant kills (box-score header)
  direScore    Int? // Dire kills
  boxScore     String    @default("[]") // JSON per-player breakdown (hero, KDA…)
  // JSON userId → Elo change, stamped once when the result lands — the room's
  // post-game banner reads this instead of re-deriving the ladder per poll.
  eloDeltas    String    @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  players   InhouseLobbyPlayer[]
  startedBy User?                @relation("InhouseStarter", fields: [startedById], references: [id])

  // Nearly every service query filters on status (single active lobby,
  // completed-history scans).
  @@index([status])
}

model InhouseLobbyPlayer {
  id             String   @id @default(cuid())
  lobbyId        String
  userId         String
  team           Int? // null = still in the draft pool; 1|2 once picked
  isCaptain      Boolean  @default(false)
  pickIndex      Int? // 0-based order picked (captains stay null)
  mmr            Int      @default(0)
  votedMethod    String? // CAPTAIN_VOTE ballot: MMR | RECORD | VOTE
  votedNomineeId String? // player they nominated as captain (when votedMethod = VOTE)
  // Inhouse record snapshot, frozen at lobby formation (no results can land
  // while this lobby is the active one) — feeds the vote's RECORD ordering and
  // the vote/draft UI without a full-history scan on every poll.
  wins           Int      @default(0)
  losses         Int      @default(0)
  games          Int      @default(0)
  createdAt      DateTime @default(now())

  lobby InhouseLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  // The "is this user in a live lobby" guard filters by userId first.
  @@index([userId])
}
