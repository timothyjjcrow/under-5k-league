// LD2L — Learn Dota 2 League
// SQLite is used for zero-config local dev + easy end-to-end testing.
// NOTE: SQLite does not support Prisma enums, so status/type/role fields are
// Strings validated in app code (see src/lib/constants.ts). This is structured
// so a later switch to Postgres (with real enums) is a mechanical change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  steamId    String   @unique
  name       String
  avatar        String?
  profileUrl    String?
  dotaAccountId Int? // Dota 2 32-bit account id (defaults to one derived from steamId)
  rankTier      Int? // OpenDota rank_tier (tens=medal, ones=stars); null if unknown
  role          String   @default("USER") // USER | ADMIN
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations       Registration[]
  teamMemberships     TeamMember[]
  captainedTeams      Team[]              @relation("TeamCaptain")
  bids                Bid[]
  standinAssignments  StandinAssignment[] @relation("StandinUser")
  replacedAssignments StandinAssignment[] @relation("ReplacedUser")
  inhouseQueue        InhouseQueueEntry?
  inhouseLobbies      InhouseLobbyPlayer[]
  startedInhouses     InhouseLobby[]      @relation("InhouseStarter")
}

model Season {
  id             String   @id @default(cuid())
  name           String
  status         String   @default("SIGNUPS") // SIGNUPS | DRAFT | REGULAR_SEASON | PLAYOFFS | COMPLETE
  minTeams       Int      @default(4)
  teamSize       Int      @default(5)
  draftBudget    Int      @default(100)
  maxMmr         Int      @default(0) // signup MMR cap; players above it can't join (0 = no cap)
  regularBestOf  Int      @default(2) // series length for regular-season matches
  playoffBestOf  Int      @default(3) // series length for playoff (non-final) matches
  finalBestOf    Int      @default(5) // series length for the grand final
  currentWeek    Int      @default(0)
  isActive       Boolean  @default(true)
  championTeamId String?
  dotaLeagueId   String? // optional Valve league id, if the league is ticketed
  matchSchedule  String? // weekly match slot shown before signup (null = app default)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registrations Registration[]
  teams         Team[]
  draft         Draft?
  matches       Match[]
  teamMembers   TeamMember[]
  bids          Bid[]
}

model Registration {
  id           String   @id @default(cuid())
  seasonId     String
  userId       String
  type         String   @default("PLAYER") // PLAYER | STANDIN
  mmr          Int      @default(0)
  wantsCaptain   Boolean  @default(false)
  roles          String   @default("") // preferred positions, comma-separated 1-5
  favoriteHeroes String   @default("")
  statement      String   @default("") // what the player wants from the league
  captainNote    String   @default("") // message to captains/drafters
  status         String   @default("ACTIVE") // ACTIVE | WITHDRAWN
  createdAt      DateTime @default(now())

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
}

model Team {
  id         String   @id @default(cuid())
  seasonId   String
  name       String
  captainId  String
  budget     Int      @default(100)
  draftOrder Int      @default(0)
  createdAt  DateTime @default(now())

  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  captain     User         @relation("TeamCaptain", fields: [captainId], references: [id])
  members     TeamMember[]
  bids        Bid[]
  homeMatches Match[]      @relation("HomeTeam")
  awayMatches Match[]      @relation("AwayTeam")

  @@unique([seasonId, captainId])
}

model TeamMember {
  id        String   @id @default(cuid())
  seasonId  String
  teamId    String
  userId    String
  price     Int      @default(0)
  isCaptain Boolean  @default(false)
  createdAt DateTime @default(now())

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
}

// Singleton per season — server-authoritative auction draft state.
model Draft {
  id               String    @id @default(cuid())
  seasonId         String    @unique
  status           String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | PAUSED | COMPLETE
  nominatorTeamId  String?
  nominatedUserId  String?
  currentBid       Int       @default(0)
  currentBidTeamId String?
  bidEndsAt        DateTime?
  nominationEndsAt DateTime? // deadline for the team on the clock to nominate
  nominationIndex  Int       @default(0)
  updatedAt        DateTime  @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  bids   Bid[]
}

model Bid {
  id        String   @id @default(cuid())
  draftId   String
  seasonId  String
  teamId    String
  userId    String // the player being bid on
  amount    Int
  createdAt DateTime @default(now())

  draft  Draft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
}

model Match {
  id           String    @id @default(cuid())
  seasonId     String
  week         Int
  phase        String    @default("REGULAR") // REGULAR | PLAYOFF | FINAL
  homeTeamId   String
  awayTeamId   String
  scheduledAt  DateTime?
  status       String    @default("SCHEDULED") // SCHEDULED | LIVE | COMPLETED
  homeScore    Int       @default(0)
  awayScore    Int       @default(0)
  bestOf       Int       @default(1) // series length; a team clinches at floor(bestOf/2)+1
  winnerTeamId String?
  bracketSlot  String?
  createdAt    DateTime  @default(now())

  season   Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeam Team                @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team                @relation("AwayTeam", fields: [awayTeamId], references: [id])
  standins StandinAssignment[]
  games    Game[]
}

model StandinAssignment {
  id              String   @id @default(cuid())
  matchId         String
  teamId          String
  standinUserId   String
  replacingUserId String?
  createdAt       DateTime @default(now())

  match    Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  standin  User  @relation("StandinUser", fields: [standinUserId], references: [id])
  replaced User? @relation("ReplacedUser", fields: [replacingUserId], references: [id])
}

// An individual Dota 2 game fetched from OpenDota, rolled up into a league Match.
// A league Match (series) can contain several games (Bo1/Bo2/Bo3…).
model Game {
  id            String   @id @default(cuid())
  matchId       String
  dotaMatchId   String   @unique
  radiantWin    Boolean
  durationSecs  Int      @default(0)
  startTime     Int      @default(0)
  radiantScore  Int      @default(0)
  direScore     Int      @default(0)
  radiantTeamId String?
  direTeamId    String?
  winnerTeamId  String?
  players       String   @default("[]") // JSON: per-player stats mapped to our users where known
  fetchedAt     DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

// Simple key/value store for global config (e.g. activeSeasonId).
model Setting {
  key   String @id
  value String
}

// ---------------------------------------------------------------------------
// Inhouse — a casual pick-up-game mode, entirely separate from the league. A
// rolling queue: once INHOUSE.LOBBY_SIZE players are waiting a lobby forms, the
// two highest-MMR players captain, and they draft the rest back-and-forth.
// ---------------------------------------------------------------------------

// A single global queue of players waiting for the next inhouse. One row per
// user (a user can only wait once); the earliest to join are pulled into a lobby.
model InhouseQueueEntry {
  id       String   @id @default(cuid())
  userId   String   @unique
  mmr      Int      @default(0) // snapshot used to seed captains
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// A formed inhouse game + its live captain draft. Server-authoritative, like the
// league Draft: the pick clock is enforced lazily on poll (no cron/websocket).
model InhouseLobby {
  id          String    @id @default(cuid())
  status      String    @default("CAPTAIN_VOTE") // CAPTAIN_VOTE | DRAFTING | READY | IN_PROGRESS | COMPLETED | CANCELLED
  voteEndsAt  DateTime? // captain-selection vote deadline (CAPTAIN_VOTE phase)
  pickTeam    Int? // 1 | 2 — team on the clock while DRAFTING
  pickEndsAt  DateTime? // captain auto-picks when this passes
  radiantTeam Int       @default(1) // which team (1|2) plays Radiant
  winnerTeam  Int? // 1 | 2 once a result is reported
  startedById String? // who launched the in-game lobby
  startedAt   DateTime? // when the game was launched (IN_PROGRESS)
  dotaMatchId String? // OpenDota match id, once the result is recorded
  detectedAt  DateTime? // throttles the automatic OpenDota result scan
  durationSecs Int? // game length once recorded
  radiantScore Int? // Radiant kills (box-score header)
  direScore    Int? // Dire kills
  boxScore     String    @default("[]") // JSON per-player breakdown (hero, KDA…)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  players   InhouseLobbyPlayer[]
  startedBy User?                @relation("InhouseStarter", fields: [startedById], references: [id])
}

model InhouseLobbyPlayer {
  id             String   @id @default(cuid())
  lobbyId        String
  userId         String
  team           Int? // null = still in the draft pool; 1|2 once picked
  isCaptain      Boolean  @default(false)
  pickIndex      Int? // 0-based order picked (captains stay null)
  mmr            Int      @default(0)
  votedMethod    String? // CAPTAIN_VOTE ballot: MMR | RECORD | VOTE
  votedNomineeId String? // player they nominated as captain (when votedMethod = VOTE)
  createdAt      DateTime @default(now())

  lobby InhouseLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}
