# Copy to .env and fill in.
DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"
STEAM_API_KEY=""
ALLOW_DEV_LOGIN="true"
APP_URL="http://localhost:3000"
# Comma-separated SteamID64s. When set, this is AUTHORITATIVE: exactly these
# accounts are admins (everyone else is demoted on login). Leave empty to
# fall back to bootstrapping the first-ever user as admin.
ADMIN_STEAM_IDS=""
OPENDOTA_API_KEY=""
# Canonical public site origin for social-preview (OG/Twitter) images. On Vercel
# this is auto-detected from the deployment; set it only to pin a custom domain,
# e.g. "https://under5k.gg". Must include the scheme and no trailing slash.
NEXT_PUBLIC_SITE_URL=""
NEXT_PUBLIC_APP_NAME="Under 5k League"
